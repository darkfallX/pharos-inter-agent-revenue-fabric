# Pharos Inter-Agent Revenue Fabric - Environment Configuration
# Copy to .env and fill in values before running live payments.

# Wallet (required for register, live payments, proof recording, and sign-stack)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Network selection
# pharos-mainnet is the default. pharos-atlantic is the FREE path for a real
# onchain settlement: faucet PHRS gas + Circle testnet USDC + public explorer.
PHAROS_NETWORK=pharos-mainnet
PHAROS_RPC=https://rpc.pharos.xyz

# ── FREE testnet live-settlement preset (uncomment to use Pharos Atlantic) ──
# PHAROS_NETWORK=pharos-atlantic
# USDC_ADDRESS=0xcfc8330f4bcab529c625d12781b1c19466a9fc8b
# BLOCK_EXPLORER=https://pharos-testnet.socialscan.io
# DRY_RUN=false
# Faucets: https://www.gas.zip/faucet/pharos (PHRS) · https://faucet.circle.com (USDC)
# Verify the testnet RPC + USDC address against the official Pharos faucet/docs.

# On-chain SkillRevenueFabric registry contract
# Deploy contracts/SkillRevenueFabric.sol, then paste the address here.
FABRIC_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000

# USDC on the selected Pharos network (mainnet default below)
USDC_ADDRESS=0xC879C018dB60520F4355C26eD1a6D572cdAC1815

# Block explorer base URL (overrides networks.json; tx links use it)
BLOCK_EXPLORER=

# API server
PORT=4020
HOST=0.0.0.0

# Fabric tuning
# Depth decay factor for royalty weighting (0.85 = 15% decay per depth level)
DEPTH_DECAY=0.85

# Set true to calculate splits without sending on-chain payments.
DRY_RUN=true

# Require valid per-frame call-stack signatures in trace requests.
REQUIRE_FRAME_SIGNATURES=false

# x402 facilitator.
# In live mode, a configured facilitator is tried first.
# Set X402_STRICT=true to fail instead of falling back to direct USDC transfer.
X402_FACILITATOR_URL=
X402_STRICT=false

# Graph and registry cache storage
GRAPH_DATA_PATH=./data/graph.jsonl
REGISTRY_CACHE_PATH=./data/registry-cache.json
